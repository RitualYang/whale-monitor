# ─── Ethereum (Etherscan，ZAN WS 开启后不再使用）────────────────────────────
ETHERSCAN_API_KEY=your_etherscan_api_key_here
ETH_POLL_SECONDS=4

# ─── ZAN API Key（明文，只需改这一处）───────────────────────────────────────
ZAN_API_KEY=your_zan_api_key_here

# ─── ZAN 节点基础路径（不含 apiKey，程序会自动拼接 /<ZAN_API_KEY>）─────────
# ETH 优先级 1：WebSocket newHeads（实时）
ZAN_ETH_WS_BASE=wss://api.zan.top/node/ws/v1/eth/mainnet
ZAN_ETH_WS_ENABLED=false

# ETH 优先级 2：JSON-RPC HTTP（WS 关闭时自动启用）
ZAN_ETH_RPC_BASE=https://api.zan.top/node/v1/eth/mainnet

# SOL 优先级 1：WebSocket blockSubscribe（实时）
ZAN_SOL_WS_BASE=wss://api.zan.top/node/ws/v1/solana/mainnet
ZAN_WS_ENABLED=true

# SOL 优先级 2：JSON-RPC HTTP（WS 关闭时自动启用）
ZAN_SOL_RPC_BASE=https://api.zan.top/node/v1/solana/mainnet
SOL_POLL_SECONDS=8

# SOL 优先级 3：ZAN gRPC Yellowstone（需控制台开通 Geyser 权限）
ZAN_GRPC_ENDPOINT=grpc.zan.top:443
ZAN_GRPC_ENABLED=false

# ─── 阈值与存储 ───────────────────────────────────────────────────────────────
ETH_USD_THRESHOLD=100000
EVENT_STORE_LIMIT=500
CORS_ORIGINS=http://localhost:5173
