# ─── Ethereum (Etherscan free key) ────────────────────────────────────────────
ETHERSCAN_API_KEY=your_etherscan_api_key_here
ETH_POLL_SECONDS=4

# ─── ZAN Solana WebSocket（最高优先级，实时 blockSubscribe，无需额外授权）─────
ZAN_API_KEY=25a51188cb25466986e5d7e48c6217e9
ZAN_SOL_WS_URL=wss://api.zan.top/node/ws/v1/solana/mainnet/25a51188cb25466986e5d7e48c6217e9
ZAN_WS_ENABLED=true

# ─── ZAN Solana JSON-RPC（HTTP 轮询备用，WS 启用时 Solana 轮询自动关闭）────────
ZAN_SOL_RPC_URL=https://api.zan.top/node/v1/solana/mainnet/25a51188cb25466986e5d7e48c6217e9
SOL_POLL_SECONDS=8

# ─── ZAN Solana gRPC / Yellowstone（备用，需在 ZAN 控制台开通 Geyser 权限）─────
ZAN_GRPC_ENDPOINT=grpc.zan.top:443
ZAN_GRPC_ENABLED=false   # 未开通 gRPC 时保持 false；WS 已覆盖实时需求

# ─── Threshold & misc ─────────────────────────────────────────────────────────
ETH_USD_THRESHOLD=100000
EVENT_STORE_LIMIT=500
CORS_ORIGINS=http://localhost:5173
